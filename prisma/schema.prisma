// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  posts    Post[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  headerImage String    @default("")
  language    String    @default("en")
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  tags     Tag[]
  comments Comment[]

  @@map("posts")
}

model Comment {
  id          String   @id @default(cuid())
  postId      String
  displayName String
  tripcode    String?
  body        String
  createdAt   DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]

  @@map("tags")
}

enum Role {
  USER
  ADMIN
}

model ChatUser {
  id        String   @id
  ip        String
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())

  sentMessages     ChatMessage[] @relation("SentMessages")
  receivedMessages ChatMessage[] @relation("ReceivedMessages")
  blocking         ChatBlock[]   @relation("Blocker")
  blockedBy        ChatBlock[]   @relation("Blocked")

  @@map("chat_users")
}

model ChatMessage {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  content     String
  sentAt      DateTime @default(now())
  read        Boolean  @default(false)

  sender    ChatUser @relation("SentMessages",     fields: [senderId],    references: [id])
  recipient ChatUser @relation("ReceivedMessages", fields: [recipientId], references: [id])

  @@index([senderId, recipientId])
  @@index([recipientId, sentAt])
  @@map("chat_messages")
}

model ChatBlock {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker ChatUser @relation("Blocker", fields: [blockerId], references: [id])
  blocked ChatUser @relation("Blocked", fields: [blockedId], references: [id])

  @@id([blockerId, blockedId])
  @@map("chat_blocks")
}
