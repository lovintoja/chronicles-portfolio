# NextAuth v5
AUTH_URL=""              # Production URL e.g. https://yourdomain.com (omit trailing slash)
AUTH_SECRET=""           # openssl rand -base64 32
AUTH_GITHUB_ID=""        # GitHub OAuth App Client ID
AUTH_GITHUB_SECRET=""    # GitHub OAuth App Client Secret

# Admin
ADMIN_EMAIL=""           # GitHub account email — only this email can sign in
ADMIN_GITHUB_LOGIN=""    # GitHub username (fallback if email privacy is on)
TRIPCODE_SECRET=""       # openssl rand -base64 32

# Database (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Contact Form (Nodemailer SMTP)
CONTACT_EMAIL_TO=""      # Your receiving email address
SMTP_HOST=""             # e.g. smtp.gmail.com
SMTP_PORT="587"          # 587 for TLS, 465 for SSL
SMTP_USER=""             # SMTP username / email
SMTP_PASS=""             # SMTP password or app password

# Nextcloud image hosting
NEXTCLOUD_URL=""             # e.g. https://cloud.yourdomain.com (no trailing slash)
NEXTCLOUD_USER=""            # Nextcloud username for the service account
NEXTCLOUD_APP_PASSWORD=""    # Generated in Nextcloud Settings → Security → App passwords
